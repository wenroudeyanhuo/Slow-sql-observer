# HTTP server address for the web UI and API.
SSO_SERVER_ADDR=:8080

# Directory that contains the static web files.
SSO_WEB_DIR=./web

# Logical name for the observed MySQL source.
# Changing the identity name or observed slow-log path creates a new source lineage.
SSO_SOURCE_INSTANCE_NAME=local-mysql

# Source log mode:
# - local_file: read the slow log directly from the local filesystem
# - mysql_auto: connect to the source MySQL to discover slow-log configuration and choose acquisition mode
# - ssh_pull: pull the remote slow log through SSH into a local spool file first (V3 compat)
SSO_SOURCE_MODE=local_file

# Legacy alias (deprecated, use SSO_SOURCE_MODE instead):
# SSO_SOURCE_LOG_MODE=local_file

# Local-file mode path.
# Keep this set for local_file mode. In ssh_pull mode it can stay empty.
SSO_SOURCE_SLOW_LOG_PATH=./scripts/sample-slow.log

# Optional source database connection used only for validation and metadata enrichment.
# In mysql_auto mode this is REQUIRED and becomes the primary source contract.
# In other modes it is optional and used only for metadata enrichment.
SSO_SOURCE_DB_DSN=

# Optional display metadata for the observed source.
SSO_SOURCE_TIMEZONE=
SSO_SOURCE_DESCRIPTION=Local sample source

# SSH acquisition settings for ssh_pull mode and mysql_auto FILE branch.
# The remote host must be a Linux/OpenSSH environment with a readable MySQL slow log.
# In mysql_auto mode, these are required for the mysql_file effective mode.
SSO_SOURCE_REMOTE_HOST=
SSO_SOURCE_REMOTE_PORT=22
SSO_SOURCE_REMOTE_USER=
# Remote slow log path override.
# In ssh_pull mode this is required.
# In mysql_auto mode this is optional and overrides the MySQL-discovered file path.
SSO_SOURCE_REMOTE_SLOW_LOG_PATH=
SSO_SOURCE_SSH_PRIVATE_KEY_PATH=
SSO_SOURCE_SSH_KNOWN_HOSTS_PATH=

# Local spool directory for ssh_pull mode.
# Slow SQL Observer writes pulled remote bytes here before parsing.
SSO_SOURCE_LOCAL_SPOOL_DIR=./var/spool

# First-run remote position:
# - start: backfill from the current remote file head
# - end: start from the current remote file tail
SSO_SOURCE_INITIAL_POSITION=end

# Maximum allowed local spool size in bytes for ssh_pull mode.
SSO_SOURCE_LOCAL_SPOOL_MAX_BYTES=67108864

# Analysis database used by Slow SQL Observer to store parsed records and aggregates.
# The configured user should be able to create schemas and tables on first run.
SSO_ANALYSIS_DB_DSN=root:root@tcp(127.0.0.1:3306)/
SSO_ANALYSIS_DB_SCHEMA=slow_sql_observer

# Collector runtime settings.
SSO_COLLECTOR_POLL_INTERVAL=15s

# Raw-record retention in days.
# 0 disables cleanup.
SSO_RAW_RECORD_RETENTION_DAYS=0

# Analysis-layer minimum query time in seconds.
# This does not change what MySQL writes to the slow log.
# It only controls which records appear in the default overview and ranking views.
# Set to 0 to disable analysis-layer filtering.
SSO_ANALYSIS_MIN_QUERY_TIME_SEC=1

# Application log level.
SSO_LOG_LEVEL=info

# V1 compatibility names are still accepted for one transition cycle:
# SSO_INSTANCE_NAME
# SSO_SLOW_LOG_PATH
# SSO_DB_DSN
# SSO_DB_SCHEMA
#
# V3 compatibility:
# SSO_SOURCE_LOG_MODE is deprecated; use SSO_SOURCE_MODE instead.
# SSO_SOURCE_REMOTE_SLOW_LOG_PATH is no longer the primary remote input in mysql_auto mode.
