# HTTP server address for the web UI and API.
# Change this if port 8080 is already in use.
SSO_SERVER_ADDR=:8080

# Directory that contains the static web files.
SSO_WEB_DIR=./web

# Logical name for the observed MySQL instance.
# Keep this stable so collector checkpoints stay associated with the same source.
SSO_INSTANCE_NAME=local-mysql

# Path to the MySQL slow query log file.
# The default points to the sample log bundled with this repository.
SSO_SLOW_LOG_PATH=./scripts/sample-slow.log

# How often the collector polls the slow log for new events.
SSO_COLLECTOR_POLL_INTERVAL=15s

# MySQL DSN used by the application.
# The configured user should be able to create schemas and tables on first run.
# Format: username:password@tcp(host:port)/
SSO_DB_DSN=root:root@tcp(127.0.0.1:3306)/

# Analysis schema used by Slow SQL Observer.
# The application creates this schema automatically if it does not exist.
SSO_DB_SCHEMA=slow_sql_observer
